{
  "title": "Microservicios Overview",
  "uid": "microservicios-overview",
  "version": 1,
  "tags": ["microservicios", "overview"],
  "timezone": "browser",
  "editable": true,
  "refresh": "15s",
  "schemaVersion": 38,
  "panels": [
    {
      "id": 1,
      "title": "Servicios UP",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(up == 1)",
          "legendFormat": "Servicios activos"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 3 },
              { "color": "green", "value": 6 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Total Requests (último 5m)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(gateway_http_requests_total[5m]))",
          "legendFormat": "Requests"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 3,
      "title": "Tasa de error (último 5m)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total{status=~\"5..\"}[5m])) / sum(rate(gateway_http_requests_total[5m])) * 100",
          "legendFormat": "Error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "min": 0,
          "max": 100
        }
      }
    },
    {
      "id": 4,
      "title": "Servicios con estado DOWN",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(up == 0)",
          "legendFormat": "Servicios caídos"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "Empleados creados (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(empleados_creados_total[24h])",
          "legendFormat": "Empleados"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 6,
      "title": "Vacaciones programadas (24h)",
      "type": "stat",
      "gridPos": { "h": 6, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(vacaciones_creadas_total[24h])",
          "legendFormat": "Vacaciones"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      }
    },
    {
      "id": 7,
      "title": "Latencia P95 por ruta (API Gateway)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(gateway_http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{ route }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "lineInterpolation": "smooth",
            "spanNulls": false
          }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 8,
      "title": "Requests por segundo (API Gateway)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total[1m]))",
          "legendFormat": "RPS total"
        },
        {
          "expr": "sum(rate(gateway_http_requests_total{status=~\"2..\"}[1m]))",
          "legendFormat": "2xx"
        },
        {
          "expr": "sum(rate(gateway_http_requests_total{status=~\"4..\"}[1m]))",
          "legendFormat": "4xx"
        },
        {
          "expr": "sum(rate(gateway_http_requests_total{status=~\"5..\"}[1m]))",
          "legendFormat": "5xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "lineInterpolation": "smooth" }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 9,
      "title": "Salud de Microservicios",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "up",
          "legendFormat": "{{ job }}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "instance": true,
              "__name__": true
            },
            "indexByName": {},
            "renameByName": {
              "job": "Servicio",
              "Value": "Estado (#1)"
            }
          }
        },
        {
          "id": "convertFieldType",
          "options": {
            "fields": {
              "Estado": {
                "type": "number"
              }
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red" },
                "1": { "text": "UP", "color": "green" }
              }
            }
          ]
        }
      }
    },
    {
      "id": 10,
      "title": "Errores 5xx por servicio (última hora)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(gateway_http_requests_total{status=~\"5..\"}[5m])) by (job)",
          "legendFormat": "{{ job }}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "rps",
          "custom": { "lineInterpolation": "smooth" }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max", "sum"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 11,
      "title": "Memoria Heap JVM - Autenticación",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"autenticacion\", area=\"heap\"}",
          "legendFormat": "Usada"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"autenticacion\", area=\"heap\"}",
          "legendFormat": "Máxima"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineInterpolation": "smooth" }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 12,
      "title": "Memoria Heap JVM - Gestión Empleados",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 6, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{job=\"gestion-empleados\", area=\"heap\"}",
          "legendFormat": "Usada"
        },
        {
          "expr": "jvm_memory_max_bytes{job=\"gestion-empleados\", area=\"heap\"}",
          "legendFormat": "Máxima"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "lineInterpolation": "smooth" }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 13,
      "title": "Threads Activos JVM - Autenticación",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"autenticacion\"}",
          "legendFormat": "Threads activos"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineInterpolation": "smooth" }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "id": 14,
      "title": "Threads Activos JVM - Gestión Empleados",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 22 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{job=\"gestion-empleados\"}",
          "legendFormat": "Threads activos"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineInterpolation": "smooth" }
        }
      },
      "options": {
        "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      }
    }
  ]
}
