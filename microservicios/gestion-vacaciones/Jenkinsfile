pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'gestion-vacaciones'
        DOCKER_BUILDKIT = '0'
        GOFLAGS = '-mod=mod'
        GOPATH = "${WORKSPACE}/.go"
        GOMODCACHE = "${WORKSPACE}/.go/mod"
    }
    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }
        stage('Build') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        dir('microservicios/gestion-vacaciones') {
                            sh 'go mod download'
                            sh 'go build ./...'
                        }
                    }
                }
            }
        }
        stage('Test') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        dir('microservicios/gestion-vacaciones') {
                            sh """
                                go test ./internal/repository/... ./tests/... -cover -coverprofile=coverage.out -coverpkg=./... -v 2>&1 | tee test_output.txt
                            """
                        }
                    }
                }
            }
            post {
                always {
                    echo "Tests completados. Los resultados se muestran arriba en la consola."
                    sh 'rm -f test_output.txt'
                }
            }
        }
        stage('Quality') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        dir('microservicios/gestion-vacaciones') {
                            sh """
                                if [ ! -f coverage.out ]; then
                                    echo "ERROR: Archivo coverage.out no encontrado"
                                    exit 1
                                fi
                                echo "=== Cobertura por funcion ==="
                                go tool cover -func=coverage.out
                                echo "============================="
                                COBERTURA=\$(go tool cover -func=coverage.out | grep total | awk '{print \$3}' | sed 's/%//')
                                echo "Cobertura total: \${COBERTURA}%"
                                if [ \$(echo "\${COBERTURA} < 20" | bc -l) -eq 1 ]; then
                                    echo "Cobertura \${COBERTURA}% es menor al 20% requerido"
                                    exit 1
                                fi
                                echo "Cobertura \${COBERTURA}% - OK"
                            """
                        }
                    }
                }
            }
        }
        stage('Package') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        dir('microservicios/gestion-vacaciones') {
                            sh 'docker pull golang:1.22-alpine || true'
                            sh 'docker build --no-cache --pull -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                            sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                        }
                    }
                }
            }
        }
    }
    post {
        success { echo "Pipeline ${env.IMAGE_NAME} completado exitosamente" }
        failure { echo "Pipeline ${env.IMAGE_NAME} fallo en stage: ${env.STAGE_NAME}" }
        always { cleanWs() }
    }
}