pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'gestion-vacaciones'
        DOCKER_BUILDKIT = '1'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir('microservicios/gestion-vacaciones') {
                    sh 'go mod download'
                    sh 'go build ./...'
                }
            }
        }
        stage('Test') {
            steps {
                dir('microservicios/gestion-vacaciones') {
                    sh """
                        go test ./internal/service/... ./internal/handlers/... ./internal/repository/... ./pkg/middleware/... ./tests/... -cover -coverprofile=coverage.out -v 2>&1 | tee test_output.txt
                    """
                }
            }
            post {
                always {
                    junit 'report.xml'
                }
            }
        }
        stage('Quality') {
            steps {
                dir('microservicios/gestion-vacaciones') {
                    sh """
                        COBERTURA=\$(go tool cover -func=coverage.out | grep total | awk '{print \$3}' | sed 's/%//')
                        echo "Cobertura: \${COBERTURA}%"
                        if [ \$(echo "\${COBERTURA} < 70" | bc -l) -eq 1 ]; then
                            echo "Cobertura \${COBERTURA}% es menor al 70% requerido"
                            exit 1
                        fi
                        echo "Cobertura \${COBERTURA}% - OK"
                    """
                }
            }
        }
        stage('Package') {
            steps {
                dir('microservicios/gestion-vacaciones') {
                    sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                    sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                }
            }
        }
    }
    post {
        success { echo "Pipeline ${env.IMAGE_NAME} completado exitosamente" }
        failure { echo "Pipeline ${env.IMAGE_NAME} fallo en stage: ${env.STAGE_NAME}" }
        always { cleanWs() }
    }
}
