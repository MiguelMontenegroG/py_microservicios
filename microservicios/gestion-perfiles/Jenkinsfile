pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'gestion-perfiles'
        DOCKER_BUILDKIT = '1'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir('microservicios/gestion-perfiles') {
                    sh 'pip install --no-cache-dir -r requirements.txt'
                }
            }
        }
        stage('Test') {
            steps {
                dir('microservicios/gestion-perfiles') {
                    sh 'pytest --cov=src --cov-report=xml --cov-report=term --junitxml=reports/junit.xml tests/'
                }
            }
            post {
                always {
                    junit 'microservicios/gestion-perfiles/reports/junit.xml'
                }
            }
        }
        stage('Quality') {
            steps {
                dir('microservicios/gestion-perfiles') {
                    sh 'pytest --cov=src --cov-fail-under=70 --cov-report=term -q tests/'
                }
            }
        }
        stage('Package') {
            steps {
                dir('microservicios/gestion-perfiles') {
                    sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                    sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                }
            }
        }
    }
    post {
        failure {
            echo "Pipeline fallo para ${IMAGE_NAME}"
        }
        success {
            echo "Pipeline completado exitosamente para ${IMAGE_NAME}"
        }
        always {
            cleanWs()
        }
    }
}
