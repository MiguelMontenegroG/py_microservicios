pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'gestion-perfiles'
        DOCKER_BUILDKIT = '0'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        dir('microservicios/gestion-perfiles') {
                            sh '''
                                python3 -m venv venv
                                . venv/bin/activate
                                pip install --no-cache-dir -r requirements.txt
                            '''
                        }
                    }
                }
            }
        }
        stage('Test') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        dir('microservicios/gestion-perfiles') {
                            sh '''
                                . venv/bin/activate
                                pytest --cov=src --cov-report=xml --cov-report=term --junitxml=reports/junit.xml tests/
                            '''
                        }
                    }
                }
            }
            post {
                always {
                    junit 'microservicios/gestion-perfiles/reports/junit.xml'
                }
            }
        }
        stage('Quality') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        dir('microservicios/gestion-perfiles') {
                            sh '''
                                . venv/bin/activate
                                pytest --cov=src --cov-fail-under=65 --cov-report=term -q tests/
                            '''
                        }
                    }
                }
            }
        }
        stage('Package') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                        dir('microservicios/gestion-perfiles') {
                            sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                            sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                        }
                    }
                }
            }
        }
    }
    post {
        failure {
            echo "Pipeline falló para ${IMAGE_NAME}"
        }
        success {
            echo "Pipeline completado exitosamente para ${IMAGE_NAME}"
        }
        always {
            cleanWs()
        }
    }
}