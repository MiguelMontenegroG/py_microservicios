pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'gestion-empleados'
        DOCKER_BUILDKIT = '0'
        // Deshabilitar Ryuk (contenedor auxiliar de Testcontainers) porque
        // en entornos Docker-in-Docker no puede conectarse correctamente.
        // Los contenedores se limpiarán automáticamente al finalizar el pipeline.
        TESTCONTAINERS_RYUK_DISABLED = 'true'
        // Deshabilitar reuse de contenedores para entornos CI
        TESTCONTAINERS_REUSE_ENABLE = 'false'
        // Variable para almacenar la IP del host Docker (se calcula en el stage)
        DOCKER_HOST_IP = ''
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'mvn clean compile -q'
                }
            }
        }
        stage('Unit Tests') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh "mvn test -DfailIfNoTests=false"
                }
            }
            post {
                always {
                    junit 'microservicios/gestion-empleados/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Integration Tests') {
            steps {
                dir('microservicios/gestion-empleados') {
                    // En Docker-in-Docker, los contenedores que Testcontainers crea
                    // (PostgreSQL, RabbitMQ) se ejecutan en el host Docker, pero el
                    // contenedor Jenkins no puede acceder a ellos via 172.17.0.1
                    // porque esta en una red personalizada (cicd-network).
                    //
                    // TESTCONTAINERS_HOST_OVERRIDE le dice a Testcontainers que informe
                    // a la aplicacion que use esta IP para conectarse a los contenedores.
                    // La IP se obtiene del gateway de red del contenedor Jenkins, que
                    // es la IP del host Docker accesible desde la red de Jenkins.
                    script {
                        DOCKER_HOST_IP = sh(
                            script: """
                                # Intentar obtener la IP del gateway (host Docker)
                                # desde la perspectiva del contenedor Jenkins
                                GW_IP=""

                                # Metodo 1: ip route (iproute2, disponible en Debian)
                                if command -v ip &> /dev/null; then
                                    GW_IP=\$(ip route | grep default | awk '{print \$3}' 2>/dev/null)
                                fi

                                # Metodo 2: /proc/net/route (disponible en cualquier Linux)
                                if [ -z "\$GW_IP" ]; then
                                    GW_IP_HEX=\$(awk '\$2 == "00000000" {print \$3}' /proc/net/route 2>/dev/null | head -1)
                                    if [ -n "\$GW_IP_HEX" ]; then
                                        # Convertir hex LE a IP decimal
                                        GW_IP=\$(echo "\$GW_IP_HEX" | awk '{
                                            split(\$0, hex, "");
                                            printf "%d.%d.%d.%d", strtonum("0x" hex[7] hex[8]), strtonum("0x" hex[5] hex[6]), strtonum("0x" hex[3] hex[4]), strtonum("0x" hex[1] hex[2])
                                        }' 2>/dev/null)
                                    fi
                                fi

                                # Metodo 3: host.docker.internal (Docker Desktop)
                                if [ -z "\$GW_IP" ]; then
                                    GW_IP=\$(getent hosts host.docker.internal | awk '{print \$1}' 2>/dev/null)
                                fi

                                # Fallback final
                                echo "\${GW_IP:-172.17.0.1}"
                            """,
                            returnStdout: true
                        ).trim()
                        echo "DOCKER_HOST_IP detectada: ${DOCKER_HOST_IP}"
                    }
                    sh """
                        export TESTCONTAINERS_HOST_OVERRIDE=${DOCKER_HOST_IP}
                        echo "Ejecutando Integration Tests con TESTCONTAINERS_HOST_OVERRIDE=\${TESTCONTAINERS_HOST_OVERRIDE}"
                        echo "Esto indica a Testcontainers que use \${TESTCONTAINERS_HOST_OVERRIDE} como IP del host"
                        mvn test -Dtest='*IntegrationTest,*IntegrationTests' -DfailIfNoTests=false \
                            -Dtestcontainers.host.override=${DOCKER_HOST_IP}
                    """
                }
            }
            post {
                always {
                    junit 'microservicios/gestion-empleados/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Quality') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'mvn jacoco:report jacoco:check -DskipTests'
                }
            }
        }
        stage('Package') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                    sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                }
            }
        }
    }
    post {
        success { echo "Pipeline ${env.IMAGE_NAME} completado exitosamente" }
        failure { echo "Pipeline ${env.IMAGE_NAME} fallo en stage: ${env.STAGE_NAME}" }
        always { cleanWs() }
    }
}
