pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'gestion-empleados'
        DOCKER_BUILDKIT = '0'
        // Deshabilitar Ryuk (contenedor auxiliar de Testcontainers) porque
        // en entornos Docker-in-Docker no puede conectarse correctamente.
        // Los contenedores se limpiarán automáticamente al finalizar el pipeline.
        TESTCONTAINERS_RYUK_DISABLED = 'true'
        // Deshabilitar reuse de contenedores para entornos CI
        TESTCONTAINERS_REUSE_ENABLE = 'false'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'mvn clean compile -q'
                }
            }
        }
        stage('Unit Tests') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'mvn test -Dtest="*Test,*Tests,!*IntegrationTest" -DfailIfNoTests=false'
                }
            }
            post {
                always {
                    junit 'microservicios/gestion-empleados/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Integration Tests') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'mvn test -Dtest="*IntegrationTest,*IntegrationTests" -DfailIfNoTests=false -Dtestcontainers.ryuk.disabled=true -Dtestcontainers.reuse.enable=false'
                }
            }
            post {
                always {
                    junit 'microservicios/gestion-empleados/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Quality') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'mvn jacoco:report jacoco:check -DskipTests'
                }
            }
        }
        stage('Package') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                    sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                }
            }
        }
    }
    post {
        success { echo "Pipeline ${env.IMAGE_NAME} completado exitosamente" }
        failure { echo "Pipeline ${env.IMAGE_NAME} fallo en stage: ${env.STAGE_NAME}" }
        always { cleanWs() }
    }
}
