pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'gestion-empleados'
        DOCKER_BUILDKIT = '0'
        // Deshabilitar Ryuk (contenedor auxiliar de Testcontainers) porque
        // en entornos Docker-in-Docker no puede conectarse correctamente.
        // Los contenedores se limpiarán automáticamente al finalizar el pipeline.
        TESTCONTAINERS_RYUK_DISABLED = 'true'
        // Deshabilitar reuse de contenedores para entornos CI
        TESTCONTAINERS_REUSE_ENABLE = 'false'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'mvn clean compile -q'
                }
            }
        }
        stage('Unit Tests') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh "mvn test -DfailIfNoTests=false"
                }
            }
            post {
                always {
                    junit 'microservicios/gestion-empleados/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Integration Tests') {
            steps {
                dir('microservicios/gestion-empleados') {
                    // En Docker-in-Docker, los contenedores que Testcontainers crea
                    // (PostgreSQL, RabbitMQ) se ejecutan en el host Docker, no dentro
                    // del contenedor Jenkins. Como Jenkins esta en una red personalizada
                    // (cicd-network), no puede alcanzar los contenedores de Testcontainers
                    // que estan en el bridge por defecto (docker0) del host.
                    //
                    // Solucion: ejecutar los Integration Tests dentro de un contenedor
                    // Docker temporal con --network host, que tiene acceso completo a
                    // la red del host y puede ver los contenedores de Testcontainers.
                    //
                    // El contenedor usa la misma imagen Maven y monta:
                    //   - El codigo fuente (/workspace)
                    //   - El cache de Maven (~/.m2) para reutilizar dependencias
                    //   - El socket de Docker para que Testcontainers pueda crear contenedores
                    script {
                        // Asegurar que el directorio .m2 existe para compartir cache
                        sh 'mkdir -p ~/.m2'
                        def workspace = pwd()
                        def m2Cache = "${env.HOME}/.m2"
                        sh """
                            echo "=== Ejecutando Integration Tests en contenedor Docker con --network host ==="
                            echo "Workspace: ${workspace}"
                            echo "M2 cache: ${m2Cache}"
                            docker run --rm \\
                                --network host \\
                                --name it-test-${BUILD_NUMBER} \\
                                -v ${workspace}:/workspace \\
                                -v ${m2Cache}:/root/.m2 \\
                                -w /workspace \\
                                -e TESTCONTAINERS_RYUK_DISABLED=true \\
                                -e TESTCONTAINERS_REUSE_ENABLE=false \\
                                -v /var/run/docker.sock:/var/run/docker.sock \\
                                maven:3.9.6-eclipse-temurin-17 \\
                                mvn test -Dtest='*IntegrationTest,*IntegrationTests' -DfailIfNoTests=false \\
                                    -Dtestcontainers.ryuk.disabled=true \\
                                    -Dtestcontainers.reuse.enable=false
                        """
                    }
                }
            }
            post {
                always {
                    junit 'microservicios/gestion-empleados/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Quality') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'mvn jacoco:report jacoco:check -DskipTests'
                }
            }
        }
        stage('Package') {
            steps {
                dir('microservicios/gestion-empleados') {
                    sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                    sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                }
            }
        }
    }
    post {
        success { echo "Pipeline ${env.IMAGE_NAME} completado exitosamente" }
        failure { echo "Pipeline ${env.IMAGE_NAME} fallo en stage: ${env.STAGE_NAME}" }
        always { cleanWs() }
    }
}
