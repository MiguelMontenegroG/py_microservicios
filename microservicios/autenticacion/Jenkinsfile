pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'autenticacion'
        DOCKER_BUILDKIT = '0'
        // Deshabilitar Ryuk (Testcontainers) para entornos Docker-in-Docker
        TESTCONTAINERS_RYUK_DISABLED = 'true'
        TESTCONTAINERS_REUSE_ENABLE = 'false'
        DOCKER_HOST_IP = ''
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'mvn clean compile -q'
                }
            }
            post {
                success {
                    echo 'Compilacion exitosa'
                }
                failure {
                    echo 'Error en compilacion'
                }
            }
        }
        stage('Unit Tests') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'mvn test -DfailIfNoTests=false'
                }
            }
            post {
                always {
                    junit 'microservicios/autenticacion/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Integration Tests') {
            steps {
                dir('microservicios/autenticacion') {
                    script {
                        DOCKER_HOST_IP = sh(
                            script: """
                                # Obtener la IP del gateway (host Docker) desde el contenedor Jenkins
                                GW_IP=""

                                # Metodo 1: ip route (iproute2)
                                if command -v ip &> /dev/null; then
                                    GW_IP=\$(ip route | grep default | awk '{print \$3}' 2>/dev/null)
                                fi

                                # Metodo 2: /proc/net/route
                                if [ -z "\$GW_IP" ]; then
                                    GW_IP_HEX=\$(awk '\$2 == "00000000" {print \$3}' /proc/net/route 2>/dev/null | head -1)
                                    if [ -n "\$GW_IP_HEX" ]; then
                                        GW_IP=\$(echo "\$GW_IP_HEX" | awk '{
                                            split(\$0, hex, "");
                                            printf "%d.%d.%d.%d", strtonum("0x" hex[7] hex[8]), strtonum("0x" hex[5] hex[6]), strtonum("0x" hex[3] hex[4]), strtonum("0x" hex[1] hex[2])
                                        }' 2>/dev/null)
                                    fi
                                fi

                                # Metodo 3: host.docker.internal
                                if [ -z "\$GW_IP" ]; then
                                    GW_IP=\$(getent hosts host.docker.internal | awk '{print \$1}' 2>/dev/null)
                                fi

                                echo "\${GW_IP:-172.17.0.1}"
                            """,
                            returnStdout: true
                        ).trim()
                        echo "DOCKER_HOST_IP detectada: ${DOCKER_HOST_IP}"
                    }
                    sh """
                        export TESTCONTAINERS_HOST_OVERRIDE=${DOCKER_HOST_IP}
                        echo "Ejecutando Integration Tests con TESTCONTAINERS_HOST_OVERRIDE=\${TESTCONTAINERS_HOST_OVERRIDE}"
                        mvn test -Dtest='*IntegrationTest,*IntegrationTests' -DfailIfNoTests=false \
                            -Dtestcontainers.host.override=${DOCKER_HOST_IP}
                    """
                }
            }
            post {
                always {
                    junit 'microservicios/autenticacion/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Quality') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'mvn jacoco:report jacoco:check -DskipTests'
                }
            }
            post {
                success {
                    echo 'Cobertura de tests >= 70% - OK'
                }
        failure {
                    error 'La cobertura de tests es menor al 70%'
        }
    }
}
        stage('Package') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                    sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                }
            }
            post {
                success {
                    echo 'Imagen Docker generada y publicada exitosamente'
                }
            }
        }
    }
    post {
        always {
            cleanWs()
        }
        success {
            echo "Pipeline ${env.IMAGE_NAME} completado exitosamente"
        }
        failure {
            echo "Pipeline ${env.IMAGE_NAME} fallo en stage: ${env.STAGE_NAME}"
        }
    }
}
