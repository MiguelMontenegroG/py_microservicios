pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'autenticacion'
        DOCKER_BUILDKIT = '0'
        TESTCONTAINERS_RYUK_DISABLED = 'true'
        TESTCONTAINERS_REUSE_ENABLE = 'false'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'mvn clean compile -q'
                }
            }
        }
        stage('Unit Tests') {
            steps {
                dir('microservicios/autenticacion') {
                    sh "mvn test -DfailIfNoTests=false"
                }
            }
            post {
                always {
                    junit 'microservicios/autenticacion/target/surefire-reports/*.xml'
                }
            }
        }
        stage('Integration Tests') {
            steps {
                script {
                    catchError(buildResult: 'UNSTABLE', stageResult: 'UNSTABLE') {
                dir('microservicios/autenticacion') {
                            sh """
                                echo "=== Ejecutando Integration Tests en contenedor Docker ==="
                                echo "POM directory: \$(pwd)"
                                ls -la pom.xml
                                mkdir -p /root/.m2
                                echo "--- Verificando bind mount dentro del contenedor ---"
                                docker run --rm \\
                                    --network host \\
                                    --name it-test-\${BUILD_NUMBER} \\
                                    -v "\$(pwd)":/workspace \\
                                    -v /root/.m2:/root/.m2 \\
                                    -w /workspace \\
                                    -e TESTCONTAINERS_RYUK_DISABLED=true \\
                                    -e TESTCONTAINERS_REUSE_ENABLE=false \\
                                    -v /var/run/docker.sock:/var/run/docker.sock \\
                                    maven:3.9.6-eclipse-temurin-17 \\
                                    ls -la /workspace/
                            """
                        }
                    }
                }
            }
            post {
                always {
                    junit 'microservicios/autenticacion/target/surefire-reports/*.xml'
}
            }
        }
        stage('Quality') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'mvn verify -DskipTests -q'
                }
            }
        }
        stage('Package') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                    sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
}
            }
        }
    }
    post {
        success { echo "Pipeline ${env.IMAGE_NAME} completado exitosamente" }
        failure { echo "Pipeline ${env.IMAGE_NAME} fallo en stage: ${env.STAGE_NAME}" }
        always { cleanWs() }
    }
}
