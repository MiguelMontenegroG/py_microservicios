pipeline {
    agent any
    options {
        timestamps()
        ansiColor('xterm')
        timeout(time: 20, unit: 'MINUTES')
    }
    environment {
        REGISTRY = 'localhost:5050'
        IMAGE_NAME = 'autenticacion'
        DOCKER_BUILDKIT = '1'
    }
    stages {
        stage('Checkout') {
            steps { checkout scm }
        }
        stage('Build') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'mvn clean compile -q'
                }
            }
            post {
                success {
                    echo 'Compilacion exitosa'
                }
                failure {
                    echo 'Error en compilacion'
                }
            }
        }

        stage('Test') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'mvn test'
                }
            }
            post {
                always {
                    junit 'microservicios/autenticacion/target/surefire-reports/*.xml'
                }
            }
        }

        stage('Quality') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'mvn verify -DskipTests jacoco:check'
                }
            }
            post {
                success {
                    echo 'Cobertura de tests >= 70% - OK'
                }
                failure {
                    error 'La cobertura de tests es menor al 70%'
                }
            }
        }

        stage('Package') {
            steps {
                dir('microservicios/autenticacion') {
                    sh 'docker build -t ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} .'
                    sh 'docker tag ${REGISTRY}/${IMAGE_NAME}:${BUILD_NUMBER} ${REGISTRY}/${IMAGE_NAME}:latest'
                }
            }
            post {
                success {
                    echo 'Imagen Docker generada y publicada exitosamente'
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Pipeline ${env.IMAGE_NAME} completado exitosamente"
        }
        failure {
            echo "Pipeline ${env.IMAGE_NAME} fallo en stage: ${env.STAGE_NAME}"
        }
    }
}
